{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.js",
    "css": "ui/index.css",
    "baseColor": "zinc",
    "cssVariables": true,
    "prefix": "ps-"
  },
  "iconLibrary": "lucide",
  "aliases": {
